<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="ROSApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#EEF3FA" />
                    <SolidColorBrush x:Key="SidebarBrush" Color="#E6EDF7" />
                    <SolidColorBrush x:Key="SidebarPanelBrush" Color="#F3F7FD" />
                    <SolidColorBrush x:Key="SidebarButtonBgBrush" Color="#FAFCFF" />
                    <SolidColorBrush x:Key="SidebarButtonBorderBrush" Color="#CBD9EA" />
                    <SolidColorBrush x:Key="SidebarTextBrush" Color="#0F172A" />
                    <SolidColorBrush x:Key="SidebarSubTextBrush" Color="#64748B" />
                    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#D6DFEB" />
                    <SolidColorBrush x:Key="StatusCardBrush" Color="#F6F9FF" />
                    <SolidColorBrush x:Key="StatusCardBorderBrush" Color="#D8E4FA" />
                    <SolidColorBrush x:Key="ListBackgroundBrush" Color="#F8FAFD" />
                    <SolidColorBrush x:Key="ListBorderBrush" Color="#E2E8F0" />
                    <SolidColorBrush x:Key="PrimaryBrush" Color="#1D4ED8" />
                    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SecondaryBrush" Color="#E9EEF6" />
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#334155" />
                    <SolidColorBrush x:Key="TitleBrush" Color="#111827" />
                    <SolidColorBrush x:Key="BodyBrush" Color="#334155" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFD" />
                    <SolidColorBrush x:Key="InputBorderBrush" Color="#C9D4E3" />
                    <SolidColorBrush x:Key="InputForegroundBrush" Color="#0F172A" />
                    <SolidColorBrush x:Key="InputPlaceholderBrush" Color="#64748B" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#EEF3FA" />
                    <SolidColorBrush x:Key="SidebarBrush" Color="#E6EDF7" />
                    <SolidColorBrush x:Key="SidebarPanelBrush" Color="#F3F7FD" />
                    <SolidColorBrush x:Key="SidebarButtonBgBrush" Color="#FAFCFF" />
                    <SolidColorBrush x:Key="SidebarButtonBorderBrush" Color="#CBD9EA" />
                    <SolidColorBrush x:Key="SidebarTextBrush" Color="#0F172A" />
                    <SolidColorBrush x:Key="SidebarSubTextBrush" Color="#64748B" />
                    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#D6DFEB" />
                    <SolidColorBrush x:Key="StatusCardBrush" Color="#F6F9FF" />
                    <SolidColorBrush x:Key="StatusCardBorderBrush" Color="#D8E4FA" />
                    <SolidColorBrush x:Key="ListBackgroundBrush" Color="#F8FAFD" />
                    <SolidColorBrush x:Key="ListBorderBrush" Color="#E2E8F0" />
                    <SolidColorBrush x:Key="PrimaryBrush" Color="#1D4ED8" />
                    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SecondaryBrush" Color="#E9EEF6" />
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#334155" />
                    <SolidColorBrush x:Key="TitleBrush" Color="#111827" />
                    <SolidColorBrush x:Key="BodyBrush" Color="#334155" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFD" />
                    <SolidColorBrush x:Key="InputBorderBrush" Color="#C9D4E3" />
                    <SolidColorBrush x:Key="InputForegroundBrush" Color="#0F172A" />
                    <SolidColorBrush x:Key="InputPlaceholderBrush" Color="#64748B" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#0D1320" />
                    <SolidColorBrush x:Key="SidebarBrush" Color="#0A1220" />
                    <SolidColorBrush x:Key="SidebarPanelBrush" Color="#101D33" />
                    <SolidColorBrush x:Key="SidebarButtonBgBrush" Color="#12213A" />
                    <SolidColorBrush x:Key="SidebarButtonBorderBrush" Color="#253755" />
                    <SolidColorBrush x:Key="SidebarTextBrush" Color="#E5ECF7" />
                    <SolidColorBrush x:Key="SidebarSubTextBrush" Color="#93A6C2" />
                    <SolidColorBrush x:Key="CardBrush" Color="#111B2C" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#24354F" />
                    <SolidColorBrush x:Key="StatusCardBrush" Color="#17243A" />
                    <SolidColorBrush x:Key="StatusCardBorderBrush" Color="#2D4362" />
                    <SolidColorBrush x:Key="ListBackgroundBrush" Color="#0F1A2B" />
                    <SolidColorBrush x:Key="ListBorderBrush" Color="#2B3E5B" />
                    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6" />
                    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#EAF2FF" />
                    <SolidColorBrush x:Key="SecondaryBrush" Color="#22344D" />
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#DAE4F3" />
                    <SolidColorBrush x:Key="TitleBrush" Color="#F3F7FF" />
                    <SolidColorBrush x:Key="BodyBrush" Color="#B9C7DB" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#132138" />
                    <SolidColorBrush x:Key="InputBorderBrush" Color="#334969" />
                    <SolidColorBrush x:Key="InputForegroundBrush" Color="#ECF3FF" />
                    <SolidColorBrush x:Key="InputPlaceholderBrush" Color="#8EA4C2" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Foreground" Value="{ThemeResource SidebarTextBrush}" />
            <Setter Property="Background" Value="{ThemeResource SidebarButtonBgBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource SidebarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource PrimaryButtonForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource SecondaryBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{ThemeResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{ThemeResource InputForegroundBrush}" />
            <Setter Property="PlaceholderForeground" Value="{ThemeResource InputPlaceholderBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{ThemeResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{ThemeResource InputForegroundBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style x:Key="InputCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
            <Setter Property="Padding" Value="2,2,2,2" />
        </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="{ThemeResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{ThemeResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Margin="14,14,14,10" Padding="14" Background="{ThemeResource SidebarPanelBrush}" CornerRadius="14" BorderBrush="{ThemeResource SidebarButtonBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource SidebarTextBrush}" Text="ROS-APP" />
                    <TextBlock FontSize="12" Foreground="{ThemeResource SidebarSubTextBrush}" Text="对象存储控制台" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Padding="12" Spacing="8">
                <Button x:Name="NavLog" Style="{StaticResource SidebarButtonStyle}" Content="日志" Click="OnNavLog" />
                <Button x:Name="NavConnect" Style="{StaticResource SidebarButtonStyle}" Content="连接" Click="OnNavConnect" />
                <Button x:Name="NavBuckets" Style="{StaticResource SidebarButtonStyle}" Content="桶列表" Click="OnNavBuckets" />
                <Button x:Name="NavObjects" Style="{StaticResource SidebarButtonStyle}" Content="对象浏览" Click="OnNavObjects" />
                <Button x:Name="NavTransfer" Style="{StaticResource SidebarButtonStyle}" Content="上传 / 下载" Click="OnNavTransfer" />
                <Button x:Name="NavSettings" Style="{StaticResource SidebarButtonStyle}" Content="设置" Click="OnNavSettings" />
            </StackPanel>

            <StackPanel Grid.Row="2" Padding="12,0,12,12">
                <Button x:Name="NavAbout" Style="{StaticResource SidebarButtonStyle}" Content="关于" Click="OnNavAbout" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="26" Spacing="16">

                <Border Padding="18" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="340" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <TextBlock FontFamily="Segoe UI Variable Display" FontSize="30" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="ROS-APP 管理中心" />
                            <TextBlock FontSize="14" Foreground="{ThemeResource BodyBrush}" Text="支持 S3 与 SFTP：连接、浏览、传输、预览与日志追踪。" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Padding="10,6" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="10">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Foreground="{ThemeResource BodyBrush}" Text="桶数" />
                                        <TextBlock x:Name="BucketsCountText" Foreground="{ThemeResource TitleBrush}" FontWeight="SemiBold" Text="0" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="10,6" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="10">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Foreground="{ThemeResource BodyBrush}" Text="对象" />
                                        <TextBlock x:Name="ObjectsCountText" Foreground="{ThemeResource TitleBrush}" FontWeight="SemiBold" Text="0" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="10,6" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="10">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Foreground="{ThemeResource BodyBrush}" Text="传输状态" />
                                        <TextBlock x:Name="TransferSummaryText" Foreground="{ThemeResource TitleBrush}" FontWeight="SemiBold" Text="空闲" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Padding="12" Background="{ThemeResource StatusCardBrush}" BorderBrush="{ThemeResource StatusCardBorderBrush}" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="13" Foreground="{ThemeResource BodyBrush}" Text="连接状态" />
                                <TextBlock x:Name="ConnectionStatusText" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="未连接" />
                                <TextBlock x:Name="ConnectionProtocolText" FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="协议：S3" />
                                <TextBlock x:Name="ConnectionEndpointText" FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="端点：-" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="ViewLog" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="日志输出" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="复制日志" Click="OnCopyLogClicked" />
                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="清空日志" Click="OnClearClicked" />
                            </StackPanel>
                        </Grid>
                        <TextBox x:Name="LogBox" Style="{StaticResource InputTextBoxStyle}" AcceptsReturn="True" IsReadOnly="True" Height="360" FontFamily="Consolas" TextWrapping="NoWrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="ViewConnect" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Visibility="Collapsed">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="连接配置" />

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="12">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="连接协议" />
                                    <ComboBox x:Name="ProtocolCombo" Style="{StaticResource InputComboBoxStyle}" MinHeight="36" SelectedIndex="0" SelectionChanged="OnProtocolChanged">
                                        <ComboBoxItem Content="S3" />
                                        <ComboBoxItem Content="SFTP" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="S3EndpointPanel" Spacing="6">
                                    <TextBlock x:Name="EndpointLabel" FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="S3 端点地址" />
                                    <ComboBox x:Name="EndpointCombo" Style="{StaticResource InputComboBoxStyle}" MinHeight="36" SelectedIndex="0">
                                        <ComboBoxItem Content="https://cn-nb1.rains3.com" />
                                        <ComboBoxItem Content="https://cn-sy1.rains3.com" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="SftpEndpointPanel" Spacing="6" Visibility="Collapsed">
                                    <TextBlock FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="SFTP 端点地址" />
                                    <ComboBox x:Name="SftpEndpointCombo" Style="{StaticResource InputComboBoxStyle}" MinHeight="36" SelectedIndex="0">
                                        <ComboBoxItem Content="sftp://cn-nb1.rains3.com:8022" />
                                        <ComboBoxItem Content="sftp://cn-sy1.rains3.com:8022" />
                                    </ComboBox>
                                    <TextBlock FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="SFTP 使用 Access Key 作为用户名，Secret Key 作为密码。" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="12">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="AccessKeyLabel" FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="Access Key" />
                                    <TextBox x:Name="AccessKeyBox" Style="{StaticResource InputTextBoxStyle}" MinHeight="36" PlaceholderText="请输入 Access Key" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="SecretKeyLabel" FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="Secret Key" />
                                    <TextBox x:Name="SecretKeyBox" Style="{StaticResource InputTextBoxStyle}" MinHeight="36" PlaceholderText="请输入 Secret Key（可见）" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <CheckBox x:Name="UseLastKeyCheck" Style="{StaticResource InputCheckBoxStyle}" Content="使用上次 Key" />
                                    <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="清空已保存 Key" Click="OnClearSavedKey" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <ProgressRing x:Name="BusyRing" Width="18" Height="18" IsActive="False" />
                            <Button x:Name="ConnectButton" Style="{StaticResource PrimaryActionButtonStyle}" Content="连接并列出文件" Click="OnConnectClicked" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ViewBuckets" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="桶列表" />
                        <ListView x:Name="BucketsList" SelectionChanged="OnBucketSelected" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{ThemeResource TitleBrush}" Text="{Binding Name}" />
                                        <TextBlock Grid.Column="1" Foreground="{ThemeResource BodyBrush}" Text="{Binding CreatedAt}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border x:Name="ViewObjects" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Visibility="Collapsed">
                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Row="0" Grid.ColumnSpan="2" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" ColumnSpacing="10" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{ThemeResource BodyBrush}" Text="路径" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="PathBox" Style="{StaticResource InputTextBoxStyle}" MinWidth="320" IsReadOnly="True" Text="/" />
                                <TextBox Grid.Column="2" x:Name="ObjectsSearchBox" Style="{StaticResource InputTextBoxStyle}" MinWidth="260" PlaceholderText="筛选文件或文件夹" TextChanged="OnObjectsSearchTextChanged" />
                            </Grid>

                            <Grid Grid.Row="1" ColumnSpacing="10" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Foreground="{ThemeResource BodyBrush}" Text="排序" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" x:Name="ObjectsSortCombo" Style="{StaticResource InputComboBoxStyle}" SelectionChanged="OnObjectsSortChanged" SelectedIndex="0">
                                    <ComboBoxItem Content="名称" />
                                    <ComboBoxItem Content="大小" />
                                    <ComboBoxItem Content="更新时间" />
                                </ComboBox>
                                <CheckBox Grid.Column="2" x:Name="ObjectsSortDescCheck" Style="{StaticResource InputCheckBoxStyle}" Content="降序" VerticalAlignment="Center" Checked="OnObjectsSortDescChanged" Unchecked="OnObjectsSortDescChanged" />
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="清空筛选" Click="OnObjectsClearFilter" />
                                    <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="上一级" Click="OnGoUp" />
                                    <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="刷新" Click="OnRefreshObjects" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="10">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="对象列表" />
                            <TextBlock x:Name="ObjectsBucketLabel" Foreground="{ThemeResource BodyBrush}" Text="未选择桶" />

                            <TextBlock Foreground="{ThemeResource BodyBrush}" Text="文件夹" />
                            <ListView x:Name="FoldersList" Height="170" SelectionChanged="OnFolderSelected" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="{ThemeResource TitleBrush}" Text="{Binding Name}" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock Foreground="{ThemeResource BodyBrush}" Text="文件" />
                            <ListView x:Name="ObjectsList" SelectionChanged="OnObjectSelected" IsItemClickEnabled="True" ItemClick="OnObjectItemClick" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="下载" Click="OnObjectDownload" />
                                                    <MenuFlyoutItem Text="删除" Click="OnObjectDelete" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="复制对象 Key" Click="OnObjectCopyKey" />
                                                    <MenuFlyoutItem Text="复制完整路径" Click="OnObjectCopyPath" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <StackPanel Spacing="2">
                                                <TextBlock Foreground="{ThemeResource TitleBrush}" Text="{Binding Key}" />
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Foreground="{ThemeResource BodyBrush}" Text="{Binding SizeText}" />
                                                    <TextBlock Foreground="{ThemeResource BodyBrush}" Text="{Binding LastModified}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="10">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="对象预览" />
                            <TextBlock x:Name="PreviewTitle" Foreground="{ThemeResource BodyBrush}" Text="请选择对象" />
                            <TextBox x:Name="PreviewBox" Style="{StaticResource InputTextBoxStyle}" AcceptsReturn="True" IsReadOnly="True" Height="370" FontFamily="Consolas" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="ViewTransfer" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Visibility="Collapsed">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="上传 / 下载" />

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Padding="14" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <StackPanel Spacing="10">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="上传" />
                                    <TextBlock FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="目标桶" />
                                    <ComboBox x:Name="TransferBucketCombo" Style="{StaticResource InputComboBoxStyle}" DisplayMemberPath="Name" MinHeight="36" />
                                    <TextBlock FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="对象 Key（可选）" />
                                    <TextBox x:Name="TransferKeyBox" Style="{StaticResource InputTextBoxStyle}" MinHeight="36" PlaceholderText="例如: folder/ 或 folder/file.txt（留空=当前目录）" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="选择上传文件" Click="OnPickUploadFile" />
                                        <TextBlock x:Name="UploadFileLabel" Foreground="{ThemeResource BodyBrush}" Text="未选择文件" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Style="{StaticResource PrimaryActionButtonStyle}" Content="开始上传" Click="OnUploadClicked" HorizontalAlignment="Left" />
                                    <ProgressBar x:Name="UploadProgress" Height="10" Minimum="0" Maximum="100" Value="0" />
                                    <TextBlock x:Name="UploadProgressText" Foreground="{ThemeResource BodyBrush}" Text="进度：0%" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Padding="14" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <StackPanel Spacing="10">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="下载" />
                                    <TextBlock FontSize="12" Foreground="{ThemeResource BodyBrush}" Text="下载对象 Key" />
                                    <TextBox x:Name="DownloadKeyBox" Style="{StaticResource InputTextBoxStyle}" MinHeight="36" PlaceholderText="例如: folder/file.txt" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Style="{StaticResource SecondaryActionButtonStyle}" Content="选择下载目录" Click="OnPickDownloadFolder" />
                                        <TextBlock x:Name="DownloadFolderLabel" Foreground="{ThemeResource BodyBrush}" Text="未选择目录" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Style="{StaticResource PrimaryActionButtonStyle}" Content="开始下载" Click="OnDownloadClicked" HorizontalAlignment="Left" />
                                    <ProgressBar x:Name="DownloadProgress" Height="10" Minimum="0" Maximum="100" Value="0" />
                                    <TextBlock x:Name="DownloadProgressText" Foreground="{ThemeResource BodyBrush}" Text="进度：0%" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="TransferStatus" Foreground="{ThemeResource BodyBrush}" Text="" />
                    </StackPanel>
                </Border>

                <Border x:Name="ViewSettings" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Visibility="Collapsed">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="设置" />
                        <Border Padding="14" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="界面主题" />
                                <TextBlock Foreground="{ThemeResource BodyBrush}" Text="可在深色与浅色模式间切换，立即生效并自动保存。" />
                                <ComboBox x:Name="ThemeModeCombo" Style="{StaticResource InputComboBoxStyle}" Width="180" SelectionChanged="OnThemeModeChanged">
                                    <ComboBoxItem Content="浅色模式" />
                                    <ComboBoxItem Content="深色模式" />
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        <Border Padding="14" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="日志行为" />
                                <CheckBox x:Name="AutoScrollLogCheck" Style="{StaticResource InputCheckBoxStyle}" Content="日志自动滚动到末尾" Checked="OnAutoScrollLogChanged" Unchecked="OnAutoScrollLogChanged" />
                                <CheckBox x:Name="TimestampLogCheck" Style="{StaticResource InputCheckBoxStyle}" Content="日志显示时间戳" Checked="OnTimestampLogChanged" Unchecked="OnTimestampLogChanged" />
                            </StackPanel>
                        </Border>
                        <Border Padding="14" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="检查更新" />
                                <TextBlock Foreground="{ThemeResource BodyBrush}" Text="更新地址已固定。" />
                            </StackPanel>
                        </Border>
                        <TextBlock Foreground="{ThemeResource BodyBrush}" Text="后续这里将继续扩展连接策略、超时、日志级别与缓存策略。" />
                    </StackPanel>
                </Border>

                <Border x:Name="ViewAbout" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Visibility="Collapsed">
                    <StackPanel Spacing="14">
                        <Border Padding="14" Background="{ThemeResource StatusCardBrush}" BorderBrush="{ThemeResource StatusCardBorderBrush}" BorderThickness="1" CornerRadius="12">
                            <StackPanel Spacing="8">
                                <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="ROS-APP" />
                                <TextBlock Foreground="{ThemeResource BodyBrush}" Text="对象存储管理控制台（WinUI 3）" />
                                <TextBlock x:Name="AboutVersion" Foreground="{ThemeResource TitleBrush}" FontWeight="SemiBold" />
                                <TextBlock x:Name="AboutAuthor" Foreground="{ThemeResource BodyBrush}" Text="作者：Yuban-Network" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Padding="12" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="10">
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="功能能力" />
                                    <TextBlock Foreground="{ThemeResource BodyBrush}" Text="• S3 与 SFTP 统一连接" />
                                    <TextBlock Foreground="{ThemeResource BodyBrush}" Text="• 桶列表与对象浏览（类资源管理器）" />
                                    <TextBlock Foreground="{ThemeResource BodyBrush}" Text="• 对象预览、右键下载/删除、复制路径" />
                                    <TextBlock Foreground="{ThemeResource BodyBrush}" Text="• 上传/下载进度与传输状态提示" />
                                    <TextBlock Foreground="{ThemeResource BodyBrush}" Text="• 全流程日志追踪与主题切换" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Padding="12" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="10">
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="运行信息" />
                                    <TextBlock x:Name="AboutRuntime" Foreground="{ThemeResource BodyBrush}" />
                                    <TextBlock x:Name="AboutProtocols" Foreground="{ThemeResource BodyBrush}" />
                                    <TextBlock x:Name="AboutSettingsPath" Foreground="{ThemeResource BodyBrush}" TextWrapping="WrapWholeWords" />
                                    <TextBlock x:Name="AboutUpdateFeed" Foreground="{ThemeResource BodyBrush}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Padding="12" Background="{ThemeResource ListBackgroundBrush}" BorderBrush="{ThemeResource ListBorderBrush}" BorderThickness="1" CornerRadius="10">
                            <StackPanel Spacing="8">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TitleBrush}" Text="更新状态" />
                                <TextBlock x:Name="UpdateStatusText" Foreground="{ThemeResource BodyBrush}" Text="未检查更新" TextWrapping="Wrap" />
                                <TextBlock x:Name="UpdateNotesText" Foreground="{ThemeResource BodyBrush}" Text="" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="CheckUpdateButton" Style="{StaticResource SecondaryActionButtonStyle}" Content="检查更新" Click="OnCheckUpdateClicked" />
                                    <Button x:Name="OpenUpdateUrlButton" Style="{StaticResource SecondaryActionButtonStyle}" Content="打开下载页" Click="OnOpenUpdateUrlClicked" IsEnabled="False" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ContentDialog
            x:Name="ConnectedDialog"
            Title="连接状态"
            PrimaryButtonText="确定"
            DefaultButton="Primary"
            Content="已连接" />

        <ContentDialog
            x:Name="TransferDialog"
            Title="传输完成"
            PrimaryButtonText="确定"
            DefaultButton="Primary"
            Content="任务已完成" />

        <ContentDialog
            x:Name="ConfirmDeleteDialog"
            Title="确认删除"
            PrimaryButtonText="删除"
            CloseButtonText="取消"
            DefaultButton="Close"
            Content="确认删除该对象？此操作不可恢复。" />
    </Grid>
</Page>
